{
  "expo": {
    "scheme": "acme",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "name": "Squads",
    "slug": "squads-mobile",
    "icon": "./src/assets/logo.png",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "package": "com.anonymous.kit_expo_uniwind"
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.kit-expo-uniwind"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./src/assets/splash.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ]
    ],
    "platforms": [
      "ios",
      "android"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8c8e4e0f-6c02-4a33-9b8c-e0192db323e1"
      }
    }
  }
}
