{
  "expo": {
    "scheme": "squads",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "name": "Squads",
    "slug": "squads-mobile",
    "version": "1.0.0",
    "icon": "./src/assets/logo.png",
    "android": {
      "package": "xyz.squads.mobile",
      "versionCode": 1
    },
    "ios": {
      "bundleIdentifier": "xyz.squads.mobile",
      "buildNumber": "1"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./src/assets/splash.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ],
      "expo-image"
    ],
    "platforms": [
      "ios",
      "android"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8c8e4e0f-6c02-4a33-9b8c-e0192db323e1"
      }
    }
  }
}
